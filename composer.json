{
    "name": "takaram/nano-di",
    "description": "Lightweight DI Container",
    "type": "library",
    "require": {
        "php": ">=8.3",
        "psr/container": "^2.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^13.0",
        "phpstan/phpstan": "^2.1"
    },
    "license": "MIT",
    "autoload": {
        "psr-4": {
            "Takaram\\NanoDi\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Takaram\\NanoDi\\Tests\\": "tests/"
        }
    },
    "authors": [
        {
            "name": "Takuya Aramaki",
            "email": "takaram71@gmail.com"
        }
    ]
}
